#!/bin/sh
# Pre-commit hook: run lightweight secret scanner on staged files
STAGED=$(git diff --cached --name-only --diff-filter=ACM)
if [ -z "$STAGED" ]; then
  exit 0
fi
echo "$STAGED" | xargs python3 scripts/secret_scan.py || {
  echo "Pre-commit failed: potential secrets detected. Review and remove before committing." 
  exit 1
}
exit 0
